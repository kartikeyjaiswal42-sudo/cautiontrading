# CautionTrading latency benchmark — all values optional (sensible defaults baked in)

# Your deployed Worker URL
SITE_URL=https://cautiontrading.amitynoidalibrary.workers.dev

# Same WebSocket the browser opens (DevTools → Network → WS)
DELTA_WS_URL=wss://socket.india.delta.exchange

# Official Delta India REST API (global: https://api.delta.exchange)
DELTA_API_BASE=https://api.india.delta.exchange

# Symbols to compare
DELTA_SYMBOL=BTCUSD
NSE_SYMBOL=NSE:NIFTY

# Benchmark timing
CYCLE_MS=5000
DURATION_MS=120000
WS_TICK_TIMEOUT_MS=4000
